# Backend service port. Zeabur/Vercel-like platforms usually inject PORT automatically.
PORT=8014

# Frontend origins allowed by CORS. Use comma-separated URLs in production.
# Example: CORS_ORIGIN=https://your-frontend.zeabur.app,https://your-domain.com
CORS_ORIGIN=
FRONTEND_ORIGIN=

# DeepSeek / OpenAI-compatible LLM configuration.
# Keep real keys only in local .env or deployment platform environment variables.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Backward-compatible aliases supported by backend/server.js.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TIMEOUT_MS=30000
